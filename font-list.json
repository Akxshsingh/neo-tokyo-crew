{
  "name": "NEO TOKYO CREW Font Collection",
  "version": "1.0.0",
  "description": "Typography system for cyberpunk and street culture themes",
  "fonts": {
    "cyberpunk": [
      {
        "name": "Orbitron",
        "type": "google",
        "category": "sans-serif",
        "usage": "Primary cyberpunk headers and navigation",
        "weights": ["400", "700", "900"],
        "fallback": ["Arial Black", "sans-serif"],
        "loadMethod": "cdn",
        "url": "https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900"
      },
      {
        "name": "Rajdhani",
        "type": "google",
        "category": "sans-serif",
        "usage": "Body text and descriptions",
        "weights": ["300", "500", "700"],
        "fallback": ["Segoe UI", "sans-serif"],
        "loadMethod": "cdn",
        "url": "https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;500;700"
      }
    ],
    "street": [
      {
        "name": "Bangers",
        "type": "google",
        "category": "display",
        "usage": "Street culture headlines and buttons",
        "weights": ["400"],
        "fallback": ["Impact", "cursive"],
        "loadMethod": "cdn",
        "url": "https://fonts.googleapis.com/css2?family=Bangers"
      },
      {
        "name": "Rubik Glitch",
        "type": "google",
        "category": "display",
        "usage": "Graffiti displays and hero text",
        "weights": ["400"],
        "fallback": ["Arial Black", "system-ui"],
        "loadMethod": "cdn",
        "url": "https://fonts.googleapis.com/css2?family=Rubik+Glitch"
      },
      {
        "name": "Rock Salt",
        "type": "google",
        "category": "handwriting",
        "usage": "Hand-drawn tags and signatures",
        "weights": ["400"],
        "fallback": ["Comic Sans MS", "cursive"],
        "loadMethod": "cdn",
        "url": "https://fonts.googleapis.com/css2?family=Rock+Salt"
      }
    ],
    "custom": [
      {
        "name": "Cyberpunk Custom",
        "type": "local",
        "category": "display",
        "usage": "Fallback system font stack",
        "weights": ["400", "700"],
        "fallback": ["Orbitron", "Arial Black", "sans-serif"],
        "loadMethod": "local",
        "note": "System font stack - no download required"
      },
      {
        "name": "Neon Tokyo",
        "type": "custom",
        "category": "display",
        "usage": "Planned custom font (coming soon)",
        "weights": ["400"],
        "fallback": ["Rubik Glitch", "cursive"],
        "loadMethod": "local",
        "status": "in-development"
      }
    ]
  },
  "typographyScale": {
    "base": "16px",
    "scale": 1.25,
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem",
      "7xl": "4.5rem",
      "8xl": "6rem"
    }
  },
  "lineHeights": {
    "none": 1,
    "tight": 1.25,
    "snug": 1.375,
    "normal": 1.5,
    "relaxed": 1.625,
    "loose": 2
  },
  "letterSpacing": {
    "tighter": "-0.05em",
    "tight": "-0.025em",
    "normal": "0em",
    "wide": "0.025em",
    "wider": "0.05em",
    "widest": "0.1em"
  },
  "fontPairings": [
    {
      "name": "Cyberpunk Standard",
      "heading": "Orbitron",
      "body": "Rajdhani",
      "use": "Primary website typography"
    },
    {
      "name": "Street Bold",
      "heading": "Bangers",
      "body": "Rajdhani",
      "use": "Street culture sections"
    },
    {
      "name": "Graffiti Hero",
      "heading": "Rubik Glitch",
      "body": "Rajdhani",
      "use": "Hero sections and displays"
    },
    {
      "name": "Tag Style",
      "heading": "Rock Salt",
      "body": "Rajdhani",
      "use": "Tags and labels"
    }
  ],
  "performance": {
    "preconnect": [
      "https://fonts.googleapis.com",
      "https://fonts.gstatic.com"
    ],
    "fontDisplay": "swap",
    "optimization": "Use WOFF2 format for modern browsers"
  },
  "lastUpdated": "2026-01-15",
  "maintainer": "NEO TOKYO CREW",
  "contact": "fonts@neotokyo.crew"
}